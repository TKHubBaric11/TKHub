-- Load/Save Settings
function LoadSettings() 
    if not isfolder("KietHub") then makefolder("KietHub") end
    local file = "KietHub/".._G.name_game..".json"
    if isfile(file) then
        local data = game:GetService("HttpService"):JSONDecode(readfile(file))
        for k,v in pairs(data) do _G.Setting[k] = v end
    else
        writefile(file, game:GetService("HttpService"):JSONEncode(_G.Setting))
    end
end

function SaveSettings()
    writefile("KietHub/".._G.name_game..".json", 
        game:GetService("HttpService"):JSONEncode(_G.Setting))
end
