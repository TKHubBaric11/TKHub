-- GUI Helpers
function makeToggle(parent,y,text,key)
    local frame = Instance.new("Frame",parent)
    frame.Name = key frame.Position = UDim2.new(0,20,0,y) frame.Size = UDim2.new(1,-40,0,45)
    frame.BackgroundColor3 = Color3.fromRGB(255,255,255)
    
    local c = Instance.new("UICorner",frame) c.CornerRadius = UDim.new(0,12)
    local l = Instance.new("TextLabel",frame) l.Size = UDim2.new(0.7,0,1,0)
    l.BackgroundTransparency = 1 l.Font = Enum.Font.GothamSemibold l.Text = text
    l.TextColor3 = Color3.fromRGB(70,70,70) l.TextSize = 15 l.TextXAlignment = Enum.TextXAlignment.Left
    
    local t = Instance.new("TextButton",frame) t.Name = "Toggle" t.Position = UDim2.new(0.73,0,0.15,0)
    t.Size = UDim2.new(0.25,0,0.7,0) t.BackgroundColor3 = _(key) and Color3.fromRGB(40,167,69) or Color3.fromRGB(220,53,69)
    t.Text = _(key) and "ON" or "OFF" t.TextColor3 = Color3.fromRGB(255,255,255)
    t.Font = Enum.Font.GothamBold t.TextSize = 13
    
    local tc = Instance.new("UICorner",t) tc.CornerRadius = UDim.new(0,8)
    t.MouseButton1Click:Connect(function()
        local ns = not _(key) __(key,ns)
        t.Text = ns and "ON" or "OFF"
        t.BackgroundColor3 = ns and Color3.fromRGB(40,167,69) or Color3.fromRGB(220,53,69)
    end)
end

function makeSlider(parent,y,text,min,max,key)
    local frame = Instance.new("Frame",parent) frame.Position = UDim2.new(0,20,0,y)
    frame.Size = UDim2.new(1,-40,0,60) frame.BackgroundColor3 = Color3.fromRGB(255,255,255)
    local c = Instance.new("UICorner",frame) c.CornerRadius = UDim.new(0,12)
    
    local l = Instance.new("TextLabel",frame)
    l.Size = UDim2.new(1,0,0.35,0) l.BackgroundTransparency = 1 l.Font = Enum.Font.GothamSemibold
    l.Text = text .. ": " .. _(key) l.TextColor3 = Color3.fromRGB(70,70,70) l.TextSize = 15
    
    local track = Instance.new("Frame",frame) track.Position = UDim2.new(0.05,0,0.45,0)
    track.Size = UDim2.new(0.9,0,0.15,0) track.BackgroundColor3 = Color3.fromRGB(230,230,230)
    local tc = Instance.new("UICorner",track) tc.CornerRadius = UDim.new(0,8)
    
    local fill = Instance.new("Frame",track) fill.Name = "Fill" fill.BackgroundColor3 = Color3.fromRGB(52,152,219)
    fill.Size = UDim2.new((_(key)-min)/(max-min),0,1,0) fill.BorderSizePixel = 0
    local fc = Instance.new("UICorner",fill) fc.CornerRadius = UDim.new(0,8)
    
    local val = Instance.new("TextLabel",frame) val.Position = UDim2.new(0.05,0,0.65,0)
    val.Size = UDim2.new(0.9,0,0.3,0) val.BackgroundTransparency = 1 val.Font = Enum.Font.GothamBold
    val.TextColor3 = Color3.fromRGB(52,152,219) val.TextSize = 18 val.Text = _(key)
    
    local drag = false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    game:GetService("UserInputService").InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local m = game.Players.LocalPlayer:GetMouse()
            local p = math.clamp((m.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            local nv = math.floor(min + p*(max-min)) __(key,nv)
            fill.Size = UDim2.new(p,0,1,0)
            l.Text = text .. ": " .. nv val.Text = nv
        end
    end)
end

function makeButton(parent,y,text,action)
