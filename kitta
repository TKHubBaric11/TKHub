                local edit = bn.." [Lv. "..bl.."]"
                
                for _,f in pairs(game.Workspace.Monster:GetChildren()) do
                    if f:IsA("Folder") then for _,m in pairs(f:GetChildren()) do
                        if m:IsA("Model") and m.Name:find(edit) and m.Humanoid.Health>0 then
                            live = live + 1
                            _G.bossStatus[bn] = {health=m.Humanoid.Health/max=m.Humanoid.MaxHealth}
                            
                            local d = distance(m.HumanoidRootPart.Position,game.Players.LocalPlayer.Character.HumanoidRootPart.Position)
                            if d>150 then
                                tp(m.HumanoidRootPart.CFrame*CFrame.new(math.random(-25,25),30,math.random(-25,25)))
                            else
                                tp(m.HumanoidRootPart.CFrame*CFrame.new(0,12,0))
                                _G.pos_skill = m.HumanoidRootPart.CFrame
                            end
                            
                            if d<500 then autoskill() end
                            status.Text = "⚔️ Boss: "..bn.." | HP: "..math.floor((m.Humanoid.Health/m.Humanoid.MaxHealth)*100).."%"
                            return
                        end
                    end end
                end
            end
            
            status.Text = "🌐 No Bosses | Cycling Spawns ("..live..")"
        end
        
        -- Auto Drops
        if _("autodrops") then
            for _,o in pairs(workspace:GetChildren()) do
                if o.Name:find("Chest") and o:FindFirstChild("PrimaryPart") then
                    tp(o.PrimaryPart.CFrame*CFrame.new(0,5,0))
                end
            end
        end
    end) end
end)

-- Hooks & Mods
local mt = getrawmetatable(game)
local nc = mt.__namecall setreadonly(mt,false)
mt.__namecall = newcclosure(function(s,...)
    local a = {...} local m = getnamecallmethod()
    if m=="InvokeServer" and tostring(s)=="SkillAction" and typeof(a[2])=="table" 
       and a[2].Type=="Up" and _G.pos_skill then a[2].MouseHit = _G.pos_skill end
    return nc(s,unpack(a))
end) setreadonly(mt,true)

