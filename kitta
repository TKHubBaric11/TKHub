function autoskill()
    local sk = {"Z","X","C","V","F","B","E"}
    for _,s in pairs(sk) do if _(s:lower()) then 
        game:GetService("VirtualInputManager"):SendKeyEvent(true,string.byte(s),false,game)
        game:GetService("VirtualInputManager"):SendKeyEvent(false,string.byte(s),false,game)
    end end
end

